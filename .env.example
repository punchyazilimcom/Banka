# ═══════════════════════════════════════════════════════════════
#  GARANTİ TRANSFER TAKİP - Ortam Değişkenleri
#  Bu dosyayı `.env` olarak kopyalayın ve doldurun. .env'i ASLA commit'lemeyin.
# ═══════════════════════════════════════════════════════════════

# --- Backend seçimi: "firebase" veya "sqlite" ---
BACKEND_MODE=sqlite

# --- IMAP (worker mail okuyucu) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=ornek@gmail.com
IMAP_PASSWORD=uygulama-sifresi
IMAP_MAILBOX=INBOX
# Açılışta taranacak son gün sayısı
IMAP_LOOKBACK_DAYS=30
# Sadece bu gönderenden gelen mailleri işle (Garanti bildirim adresi)
IMAP_FROM_FILTER=garantibbva.com.tr

# --- Self-host SQLite backend ---
SQLITE_PATH=./data/transactions.sqlite
BACKEND_PORT=4000
# Cihazların backend'e bağlanacağı adres (core UI .env'inde VITE_ ile de kullanılır)
BACKEND_URL=http://localhost:4000

# --- Firebase backend (BACKEND_MODE=firebase ise) ---
# Worker/backend (admin) tarafı: servis hesabı JSON yolu
FIREBASE_SERVICE_ACCOUNT=./serviceAccount.json
FIREBASE_PROJECT_ID=garanti-takip

# --- Firebase Web SDK (core UI - Vite, VITE_ önekli olmalı) ---
VITE_BACKEND_MODE=sqlite
VITE_BACKEND_URL=http://localhost:4000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# --- Güvenlik ---
# PIN sunucuda değil cihazda hash'lenir; bu sadece backend API erişim anahtarı
API_SHARED_SECRET=degistir-bu-degeri
