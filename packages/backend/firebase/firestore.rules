rules_version = '2';
// Garanti Transfer Takip - Firestore güvenlik kuralları.
// Yalnızca kimliği doğrulanmış kullanıcı kendi verisine erişir.
service cloud.firestore {
  match /databases/{database}/documents {
    // İşlemler: oturum açan kullanıcı okur; yazma yalnızca worker (admin SDK,
    // kuralları atlar) tarafından yapılır → istemciden yazma kapalı.
    match /transactions/{txId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Sınıflandırma düzeltmeleri: kullanıcı okuyup yazabilir.
    match /overrides/{nameKey} {
      allow read, write: if request.auth != null;
    }
    // Kullanıcı ayarları
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
    // Push cihaz token'ları: kullanıcı kendi cihazını kaydeder; okuma worker (admin).
    match /devices/{token} {
      allow read: if false;
      allow write: if request.auth != null;
    }
  }
}
