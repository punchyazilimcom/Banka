{
  "hosting": {
    "public": "packages/core/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|webmanifest)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "firestore": {
    "rules": "packages/backend/firebase/firestore.rules",
    "indexes": "packages/backend/firebase/firestore.indexes.json"
  }
}
